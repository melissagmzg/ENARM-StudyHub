<!DOCTYPE index.html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ENARM Master - Dashboard</title>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; padding: 20px; }
        h1 { color: #1a73e8; text-align: center; }
        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; max-width: 1000px; margin: auto; }
        .card { background: white; border-radius: 15px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); transition: 0.3s; }
        .card:hover { transform: translateY(-5px); }
        .especialidad { font-weight: bold; font-size: 1.2em; margin-bottom: 10px; }
        .progreso-bar { background: #eee; border-radius: 10px; height: 10px; width: 100%; margin: 10px 0; }
        .progreso-fill { background: #34a853; height: 100%; border-radius: 10px; width: 0%; transition: width 1s; }
        .status { font-size: 0.8em; color: #666; }
        .btn-estudiar { background: #1a73e8; color: white; border: none; padding: 10px; border-radius: 5px; width: 100%; cursor: pointer; margin-top: 10px; }
    </style>
</head>
<body>

    <h1>Mi Progreso ENARM</h1>

    <div class="grid">
        <div class="card">
            <div class="especialidad">Pediatría</div>
            <div class="status">Dominio: <span style="color: #ea4335; font-weight: bold;">Crítico (15%)</span></div>
            <div class="progreso-bar"><div class="progreso-fill" style="width: 15%; background: #ea4335;"></div></div>
            <p style="font-size: 0.85em;">Próximo tema: <b>Ictericia Neonatal</b></p>
            <button class="btn-estudiar" onclick="alert('Cargando módulo de Neonatología...')">Estudiar Ahora</button>
        </div>

        <div class="card">
            <div class="especialidad">Medicina Interna</div>
            <div class="status">Dominio: <span style="color: #fbbc05; font-weight: bold;">Regular (45%)</span></div>
            <div class="progreso-bar"><div class="progreso-fill" style="width: 45%; background: #fbbc05;"></div></div>
            <p style="font-size: 0.85em;">Próximo tema: <b>Insuficiencia Cardíaca</b></p>
            <button class="btn-estudiar">Continuar</button>
        </div>

        <div class="card">
            <div class="especialidad">Gineco y Obstetricia</div>
            <div class="status">Dominio: 0%</div>
            <div class="progreso-bar"><div class="progreso-fill" style="width: 0%;"></div></div>
            <button class="btn-estudiar">Comenzar Rama</button>
        </div>
    </div>

</body>
</html>
